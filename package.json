{
  "name": "rho",
  "version": "0.1.0",
  "description": "Samuel's personal pi dotfiles: extensions, skills, prompts, and themes.",
  "private": true,
  "type": "module",
  "keywords": ["pi-package"],
  "pi": {
    "extensions": [
      "./extensions",
      "node_modules/pi-web-access/index.ts",
      "node_modules/@ayulab/pi-rewind/index.js",
      "node_modules/context-mode/build/adapters/pi/extension.js"
    ],
    "skills": [
      "./skills",
      "node_modules/pi-web-access/skills",
      "node_modules/context-mode/skills"
    ],
    "prompts": ["./prompts"],
    "themes": ["./themes"]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "link": "pi install -l $(pwd)",
    "link:global": "pi install $(pwd)"
  },
  "dependencies": {
    "pi-web-access": "^0.13.0",
    "@ayulab/pi-rewind": "^0.4.5",
    "context-mode": "^1.0.169"
  },
  "bundledDependencies": ["pi-web-access", "@ayulab/pi-rewind", "context-mode"],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "latest",
    "@earendil-works/pi-tui": "latest",
    "typescript": "^5.6.0"
  }
}
